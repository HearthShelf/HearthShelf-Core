{
  "name": "@hearthshelf/core",
  "version": "0.1.0",
  "description": "Shared types and pure logic for HearthShelf (web, hosted, mobile). Dual-consumed: bundlers read the TypeScript source via a path alias; the no-bundler server imports the compiled dist (npm run build).",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./dist/types/index.js"
    },
    "./lib/*": {
      "types": "./src/lib/*.ts",
      "default": "./dist/lib/*.js"
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "typescript": "^5.7.0"
  }
}
